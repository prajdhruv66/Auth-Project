<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <link rel="stylesheet" href="/style.css"/>
</head>
<body>
    <h1><%= user.name %>, welcome to home page...</h1>
    <p>Your role: <strong><%= user.role %></strong></p>
    <a href="/dashboard">Go to dashboard</a><br/><br/>
    <% if (user.role === 'admin') { %>
        <a href="/admin/home">Go to admin home</a><br/><br/>
        <a href="/admin/delete-user">Delete User</a><br/><br/>
        <a href="/admin/show-all-user">Access all Users</a>
    <% } %>
</body>
</html>